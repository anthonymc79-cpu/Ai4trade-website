# --- Supabase --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to the browser

# Root domain for the shared auth cookie, so a session works across both
# www.yourdomain.com and app.yourdomain.com. Leave unset in local dev.
AUTH_COOKIE_DOMAIN=.yourdomain.com

# --- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...      # Stripe Price ID for the Starter plan
STRIPE_PRICE_TEAM=price_...         # Stripe Price ID for the Team plan

# --- App / site URLs -----------------------------------------------------
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
